{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenClaw Manager",
  "version": "0.1.0",
  "identifier": "com.openclaw.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "OpenClaw Manager",
        "width": 1200,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundled": "./bundled/**/*"
    },
    "shortDescription": "",
    "longDescription": ""
  }
}
