// Prevents additional console window on Windows in release, DO NOT REMOVE!!
#![cfg_attr(not(debug_assertions), windows_subsystem = "windows")]

mod commands;
mod installer;
mod models;
mod plugins;
mod system;
mod utils;

use commands::openclaw::InstallerState;
use installer::OpenClawInstaller;
use std::sync::Arc;
use tauri::{Manager, SystemTray, SystemTrayEvent, SystemTrayMenu, SystemTrayMenuItem};
use tokio::sync::Mutex;

fn main() {
    env_logger::init();

    let tray_menu = SystemTrayMenu::new()
        .add_item(tauri::CustomMenuItem::new("show", "显示"))
        .add_native_item(SystemTrayMenuItem::Separator)
        .add_item(tauri::CustomMenuItem::new("quit", "退出"));

    let system_tray = SystemTray::new().with_menu(tray_menu);

    tauri::Builder::default()
        // .plugin(tauri_plugin_shell::init())
        .system_tray(system_tray)
        .on_system_tray_event(|app, event| match event {
            SystemTrayEvent::LeftClick {
                position: _,
                size: _,
                ..
            } => {
                let window = app.get_window("main").unwrap();
                window.show().unwrap();
                window.set_focus().unwrap();
            }
            SystemTrayEvent::MenuItemClick { id, .. } => match id.as_str() {
                "show" => {
                    let window = app.get_window("main").unwrap();
                    window.show().unwrap();
                    window.set_focus().unwrap();
                }
                "quit" => {
                    std::process::exit(0);
                }
                _ => {}
            },
            _ => {}
        })
        .manage(InstallerState {
            installer: Arc::new(Mutex::new(OpenClawInstaller::new().unwrap_or_default())),
        })
        .invoke_handler(tauri::generate_handler![
            commands::config::get_config,
            commands::config::set_config,
            commands::config::delete_config,
            commands::plugin::get_plugins,
            commands::plugin::install_plugin,
            commands::plugin::uninstall_plugin,
            commands::plugin::enable_plugin,
            commands::plugin::disable_plugin,
            commands::openclaw::check_openclaw_installation,
            commands::openclaw::install_openclaw,
            commands::openclaw::uninstall_openclaw,
            commands::openclaw::get_openclaw_config,
            commands::openclaw::update_openclaw_config,
            commands::openclaw::start_openclaw_service,
            commands::openclaw::check_system_environment,
            commands::openclaw::execute_openclaw_command,
            system::get_system_info,
        ])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}
